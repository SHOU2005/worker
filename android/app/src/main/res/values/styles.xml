<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Transparent bars so WebView fills the full screen (edge-to-edge) -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Splash screen — Android 12+ Theme.SplashScreen API.
         Background is solid black to match the launcher icon + WebView
         background. The animated icon is our adaptive-icon foreground
         (Switch wordmark, padded inside the safe zone) — the system
         fades it in/out automatically, no third-party splash library
         needed. Pre-12 devices fall back to the legacy splash drawable.
         windowSplashScreenAnimationDuration controls how long the icon
         stays visible; 800ms is the sweet spot between "too fast to
         see" and "feels slow". -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground_inset</item>
        <item name="android:windowSplashScreenAnimationDuration">800</item>
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground_inset</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <!-- Fallback drawable for Android 11 and below (Theme.SplashScreen
             still recognises android:background on legacy devices). -->
        <item name="android:background">@drawable/splash</item>
    </style>

</resources>
